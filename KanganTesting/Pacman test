<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mini Pac-Man</title>

  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #050505;
      color: white;
      font-family: Arial, sans-serif;
    }

    .game-container {
      text-align: center;
    }

    h1 {
      margin: 0 0 12px;
      color: #ffd800;
      letter-spacing: 3px;
    }

    .game-info {
      width: 456px;
      max-width: 95vw;
      margin: 0 auto 10px;
      display: flex;
      justify-content: space-between;
      font-size: 18px;
      font-weight: bold;
    }

    canvas {
      display: block;
      max-width: 95vw;
      height: auto;
      background: black;
      border: 4px solid #153cff;
      border-radius: 8px;
    }

    #message {
      min-height: 28px;
      margin: 12px 0 5px;
      color: #ffd800;
      font-size: 20px;
      font-weight: bold;
    }

    button {
      padding: 10px 22px;
      border: 0;
      border-radius: 6px;
      background: #ffd800;
      color: black;
      font-size: 16px;
      font-weight: bold;
      cursor: pointer;
    }

    button:hover {
      background: #fff16b;
    }

    .controls {
      margin-top: 10px;
      color: #bbbbbb;
      font-size: 14px;
    }
  </style>
</head>

<body>
  <main class="game-container">
    <h1>PAC-MAN</h1>

    <div class="game-info">
      <span>Score: <span id="score">0</span></span>
      <span>Lives: <span id="lives">3</span></span>
    </div>

    <canvas id="gameCanvas"></canvas>

    <div id="message">Collect every dot!</div>

    <button id="restartButton">Restart Game</button>

    <div class="controls">
      Move with Arrow Keys or WASD
    </div>
  </main>

  <script>
    "use strict";

    const MAP = [
      "###################",
      "#........#........#",
      "#.###.##.#.##.###.#",
      "#o###.##.#.##.###o#",
      "#.................#",
      "#.###.#.#####.#.###",
      "#.....#...#...#...#",
      "#####.###.#.###.###",
      "#.....#.......#...#",
      "#.###.#.##G##.#.###",
      "#.....#..GGG..#...#",
      "#.###.#.#####.#.###",
      "#.....#.......#...#",
      "#####.#.#####.#.###",
      "#........#........#",
      "#.###.##.#.##.###.#",
      "#o..#.....P.....#o#",
      "###.#.#.#####.#.#.#",
      "#.....#...#...#...#",
      "#.#######.#.#######",
      "###################"
    ];

    const TILE_SIZE = 24;
    const STEP_TIME = 145;

    const ROWS = MAP.length;
    const COLUMNS = MAP[0].length;

    const canvas = document.getElementById("gameCanvas");
    const context = canvas.getContext("2d");

    const scoreElement = document.getElementById("score");
    const livesElement = document.getElementById("lives");
    const messageElement = document.getElementById("message");
    const restartButton = document.getElementById("restartButton");

    canvas.width = COLUMNS * TILE_SIZE;
    canvas.height = ROWS * TILE_SIZE;

    const DIRECTIONS = {
      left:  { row: 0, column: -1, angle: Math.PI },
      right: { row: 0, column: 1, angle: 0 },
      up:    { row: -1, column: 0, angle: -Math.PI / 2 },
      down:  { row: 1, column: 0, angle: Math.PI / 2 }
    };

    const directionNames = Object.keys(DIRECTIONS);
    const ghostColours = ["#ff3030", "#ff9de2", "#34e5ff", "#ff9f33"];

    let board;
    let player;
    let ghosts;
    let playerStart;
    let ghostStarts;

    let score;
    let lives;
    let remainingDots;
    let powerTime;
    let gameFinished;

    function findStartingPositions() {
      ghostStarts = [];

      for (let row = 0; row < ROWS; row++) {
        for (let column = 0; column < COLUMNS; column++) {
          if (MAP[row][column] === "P") {
            playerStart = { row, column };
          }

          if (MAP[row][column] === "G") {
            ghostStarts.push({ row, column });
          }
        }
      }
    }

    function createBoard() {
      board = MAP.map(row => row.split(""));

      remainingDots = 0;

      for (let row = 0; row < ROWS; row++) {
        for (let column = 0; column < COLUMNS; column++) {
          const tile = board[row][column];

          if (tile === "." || tile === "o") {
            remainingDots++;
          }

          if (tile === "P" || tile === "G") {
            board[row][column] = " ";
          }
        }
      }
    }

    function resetPositions() {
      player = {
        row: playerStart.row,
        column: playerStart.column,
        direction: "left",
        queuedDirection: "left"
      };

      ghosts = ghostStarts.map((position, index) => ({
        row: position.row,
        column: position.column,
        startRow: position.row,
        startColumn: position.column,
        direction: directionNames[index % directionNames.length],
        colour: ghostColours[index % ghostColours.length]
      }));
    }

    function startGame() {
      score = 0;
      lives = 3;
      powerTime = 0;
      gameFinished = false;

      createBoard();
      resetPositions();
      updateInformation();

      messageElement.textContent = "Collect every dot!";
    }

    function updateInformation() {
      scoreElement.textContent = score;
      livesElement.textContent = lives;
    }

    function isWall(row, column) {
      if (
        row < 0 ||
        row >= ROWS ||
        column < 0 ||
        column >= COLUMNS
      ) {
        return true;
      }

      return board[row][column] === "#";
    }

    function canMove(entity, directionName) {
      const direction = DIRECTIONS[directionName];

      return !isWall(
        entity.row + direction.row,
        entity.column + direction.column
      );
    }

    function movePlayer() {
      if (canMove(player, player.queuedDirection)) {
        player.direction = player.queuedDirection;
      }

      if (canMove(player, player.direction)) {
        const direction = DIRECTIONS[player.direction];
        player.row += direction.row;
        player.column += direction.column;
      }
    }

    function collectDot() {
      const tile = board[player.row][player.column];

      if (tile === ".") {
        board[player.row][player.column] = " ";
        score += 10;
        remainingDots--;
      }

      if (tile === "o") {
        board[player.row][player.column] = " ";
        score += 50;
        remainingDots--;
        powerTime = 8000;
        messageElement.textContent = "Power mode!";
      }

      updateInformation();

      if (remainingDots === 0) {
        gameFinished = true;
        messageElement.textContent = "You win! Press Restart to play again.";
      }
    }

    function getPossibleDirections(ghost) {
      return directionNames.filter(direction => canMove(ghost, direction));
    }

    function chooseGhostDirection(ghost) {
      const possibleDirections = getPossibleDirections(ghost);

      if (possibleDirections.length === 0) {
        return ghost.direction;
      }

      if (powerTime > 0 || Math.random() < 0.25) {
        return possibleDirections[
          Math.floor(Math.random() * possibleDirections.length)
        ];
      }

      let bestDirection = possibleDirections[0];
      let bestDistance = Infinity;

      for (const directionName of possibleDirections) {
        const direction = DIRECTIONS[directionName];

        const nextRow = ghost.row + direction.row;
        const nextColumn = ghost.column + direction.column;

        const distance =
          Math.abs(player.row - nextRow) +
          Math.abs(player.column - nextColumn);

        if (distance < bestDistance) {
          bestDistance = distance;
          bestDirection = directionName;
        }
      }

      return bestDirection;
    }

    function moveGhosts() {
      for (const ghost of ghosts) {
        ghost.direction = chooseGhostDirection(ghost);

        if (canMove(ghost, ghost.direction)) {
          const direction = DIRECTIONS[ghost.direction];
          ghost.row += direction.row;
          ghost.column += direction.column;
        }
      }
    }

    function checkGhostCollisions() {
      for (const ghost of ghosts) {
        const collision =
          player.row === ghost.row &&
          player.column === ghost.column;

        if (!collision) {
          continue;
        }

        if (powerTime > 0) {
          score += 200;

          ghost.row = ghost.startRow;
          ghost.column = ghost.startColumn;
          ghost.direction =
            directionNames[Math.floor(Math.random() * directionNames.length)];

          updateInformation();
        } else {
          lives--;
          updateInformation();

          if (lives <= 0) {
            gameFinished = true;
            messageElement.textContent =
              "Game over! Press Restart to try again.";
          } else {
            messageElement.textContent =
              `Caught! ${lives} ${lives === 1 ? "life" : "lives"} remaining.`;

            resetPositions();
          }

          return true;
        }
      }

      return false;
    }

    function gameStep() {
      if (gameFinished) {
        return;
      }

      movePlayer();
      collectDot();

      if (checkGhostCollisions()) {
        return;
      }

      moveGhosts();
      checkGhostCollisions();

      if (powerTime > 0) {
        powerTime -= STEP_TIME;

        if (powerTime <= 0 && !gameFinished) {
          powerTime = 0;
          messageElement.textContent = "Collect every dot!";
        }
      }
    }

    function drawBoard() {
      context.fillStyle = "black";
      context.fillRect(0, 0, canvas.width, canvas.height);

      for (let row = 0; row < ROWS; row++) {
        for (let column = 0; column < COLUMNS; column++) {
          const tile = board[row][column];
          const x = column * TILE_SIZE;
          const y = row * TILE_SIZE;

          if (tile === "#") {
            context.fillStyle = "#123cff";
            context.fillRect(x + 1, y + 1, TILE_SIZE - 2, TILE_SIZE - 2);

            context.fillStyle = "#020626";
            context.fillRect(x + 5, y + 5, TILE_SIZE - 10, TILE_SIZE - 10);
          }

          if (tile === ".") {
            context.fillStyle = "#ffe0bb";
            context.beginPath();
            context.arc(
              x + TILE_SIZE / 2,
              y + TILE_SIZE / 2,
              2.5,
              0,
              Math.PI * 2
            );
            context.fill();
          }

          if (tile === "o") {
            const pulse = 5 + Math.sin(Date.now() / 130);

            context.fillStyle = "#fff4d6";
            context.beginPath();
            context.arc(
              x + TILE_SIZE / 2,
              y + TILE_SIZE / 2,
              pulse,
              0,
              Math.PI * 2
            );
            context.fill();
          }
        }
      }
    }

    function drawPlayer() {
      const centreX = player.column * TILE_SIZE + TILE_SIZE / 2;
      const centreY = player.row * TILE_SIZE + TILE_SIZE / 2;

      const facingAngle = DIRECTIONS[player.direction].angle;
      const mouthSize = 0.2 + Math.abs(Math.sin(Date.now() / 100)) * 0.2;

      context.fillStyle = "#ffd800";
      context.beginPath();
      context.moveTo(centreX, centreY);
      context.arc(
        centreX,
        centreY,
        TILE_SIZE * 0.42,
        facingAngle + mouthSize,
        facingAngle + Math.PI * 2 - mouthSize
      );
      context.closePath();
      context.fill();
    }

    function drawGhost(ghost) {
      const x = ghost.column * TILE_SIZE;
      const y = ghost.row * TILE_SIZE;
      const centreX = x + TILE_SIZE / 2;
      const centreY = y + TILE_SIZE / 2;

      const flashing =
        powerTime > 0 &&
        powerTime < 2000 &&
        Math.floor(Date.now() / 200) % 2 === 0;

      if (powerTime > 0) {
        context.fillStyle = flashing ? "white" : "#203cff";
      } else {
        context.fillStyle = ghost.colour;
      }

      context.beginPath();
      context.arc(
        centreX,
        y + TILE_SIZE * 0.47,
        TILE_SIZE * 0.4,
        Math.PI,
        0
      );

      context.lineTo(x + TILE_SIZE * 0.9, y + TILE_SIZE * 0.88);
      context.lineTo(x + TILE_SIZE * 0.72, y + TILE_SIZE * 0.72);
      context.lineTo(x + TILE_SIZE * 0.55, y + TILE_SIZE * 0.88);
      context.lineTo(x + TILE_SIZE * 0.38, y + TILE_SIZE * 0.72);
      context.lineTo(x + TILE_SIZE * 0.1, y + TILE_SIZE * 0.88);
      context.closePath();
      context.fill();

      const direction = DIRECTIONS[ghost.direction];

      context.fillStyle = "white";
      context.beginPath();
      context.arc(x + 8, y + 11, 4, 0, Math.PI * 2);
      context.arc(x + 16, y + 11, 4, 0, Math.PI * 2);
      context.fill();

      context.fillStyle = powerTime > 0 ? "white" : "#1436b8";
      context.beginPath();
      context.arc(
        x + 8 + direction.column * 1.5,
        y + 11 + direction.row * 1.5,
        2,
        0,
        Math.PI * 2
      );
      context.arc(
        x + 16 + direction.column * 1.5,
        y + 11 + direction.row * 1.5,
        2,
        0,
        Math.PI * 2
      );
      context.fill();
    }

    function draw() {
      drawBoard();
      drawPlayer();

      for (const ghost of ghosts) {
        drawGhost(ghost);
      }

      requestAnimationFrame(draw);
    }

    function changeDirection(directionName) {
      if (!gameFinished) {
        player.queuedDirection = directionName;
      }
    }

    document.addEventListener("keydown", event => {
      const controls = {
        ArrowLeft: "left",
        a: "left",
        A: "left",
        ArrowRight: "right",
        d: "right",
        D: "right",
        ArrowUp: "up",
        w: "up",
        W: "up",
        ArrowDown: "down",
        s: "down",
        S: "down"
      };

      if (controls[event.key]) {
        event.preventDefault();
        changeDirection(controls[event.key]);
      }

      if (event.code === "Space" && gameFinished) {
        startGame();
      }
    });

    restartButton.addEventListener("click", startGame);

    findStartingPositions();
    startGame();

    setInterval(gameStep, STEP_TIME);
    requestAnimationFrame(draw);
  </script>
</body>
</html>